{
  "name": "nightfall-css",
  "version": "0.1.0",
  "description": "The other theme. Reverse-engineered. Auto-generate the opposite theme from your existing UI.",
  "keywords": ["dark-mode", "light-mode", "theme", "css", "oklch", "color", "accessibility", "wcag"],
  "license": "MIT",
  "author": "nightfall",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nightfall-css": "./dist/cli/index.js",
    "nightfall": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/runtime/provider.js",
      "types": "./dist/runtime/provider.d.ts"
    },
    "./script": {
      "import": "./dist/runtime/script.js",
      "types": "./dist/runtime/script.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "boxen": "^8.0.0",
    "playwright": "^1.48.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0"
  }
}
