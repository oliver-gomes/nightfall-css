{
  "name": "nightfall",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "cd apps/web && npm run dev",
    "dev:pkg": "cd packages/nightfall-css && npm run dev",
    "build:web": "cd apps/web && npm run build",
    "build:pkg": "cd packages/nightfall-css && npm run build"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.0.0"
}
